# e2e-planner scaffold の環境変数テンプレート。
# このファイルをコピーして .env を作り、実値を入れる（.env はコミットしない）:
#   cp .env.example .env
# Playwright は dotenv を自動読込しないので、config 先頭で読むか、実行時に export する:
#   import 'dotenv/config';            // playwright.config.ts の先頭に追加する場合
#   または:  set -a; source .env; set +a; npm run e2e

# テスト対象のベースURL（playwright.config.ts の baseURL が参照）
E2E_BASE_URL=http://localhost:3000

# 認証セットアップ（auth.setup.ts）が使うログイン情報
E2E_USER=user@example.com
E2E_PASS=password

# admin など別ロールを足す場合の例:
# E2E_ADMIN_USER=admin@example.com
# E2E_ADMIN_PASS=password
