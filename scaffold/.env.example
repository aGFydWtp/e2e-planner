# e2e-planner scaffold の環境変数テンプレート。
# このファイルをコピーして .env を作り、実値を入れる（.env はコミットしない）:
#   cp .env.example .env
# playwright.config.ts が先頭で dotenv を読むので、.env があれば自動で反映される
# （無くても CI 等の実環境変数で動く。手動 export は不要）。

# テスト対象のベースURL（playwright.config.ts の baseURL が参照）
E2E_BASE_URL=http://localhost:3000

# 認証モード（playwright.config.ts の projects 構成を切り替える）
#   form           = auth.setup.ts が form ログインして storageState を自動生成（既定）
#                    採取は cookie/localStorage/IndexedDB の3種を自動カバー（Firebase 等の IndexedDB 認証も対応・要 Playwright 1.51+）
#   prebuilt-state = SSO/OTP 等で手動採取した e2e/.auth/user.json を使う（setup を組まない）
#   none           = 認証不要（storageState を持たない）
E2E_AUTH_MODE=form

# 認証セットアップ（auth.setup.ts）が使うログイン情報（form モードで使用）
E2E_USER=user@example.com
E2E_PASS=password

# admin など別ロールを足す場合の例:
# E2E_ADMIN_USER=admin@example.com
# E2E_ADMIN_PASS=password
